# 开发者 LAN 联调临时文件（git 忽略，勿提交）。
# 部分 scripts/*.py 会读写 local.properties.lan.tmp（例如 run_dev_session_lan.py）。
# 复制为 local.properties.lan.tmp 后按需填写；勿把真实 Token / API Key 提交到仓库。
#
# 普通用户安装 APK 后请在 App 内设置 Gateway，无需本文件。

sdk.dir=C\:\\Users\\你的用户名\\AppData\\Local\\Android\\Sdk

# 可选：scripts/openclaw_dev_session.py 联调
OPENCLAW_GATEWAY_HOST=192.168.x.x
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_GATEWAY_PASSWORD=your-gateway-password
