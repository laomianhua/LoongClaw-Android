<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0E0"
    android:padding="24dp">

    <TextView
        android:id="@+id/clearAllTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/clear_all_dialog_title"
        android:textColor="#FFB71C1C"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/clearAllMessage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/clearAllMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineSpacingExtra="8dp"
        android:text="@string/clear_all_dialog_message"
        android:textColor="#FF212121"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@id/confirmClearAllButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clearAllTitle" />

    <Button
        android:id="@+id/confirmClearAllButton"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#FFD32F2F"
        android:includeFontPadding="false"
        android:text="@string/clear_all_confirm"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/cancelClearAllButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clearAllMessage"
        app:layout_constraintWidth_max="360dp" />

    <Button
        android:id="@+id/cancelClearAllButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:includeFontPadding="false"
        android:text="@string/clear_all_cancel"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/confirmClearAllButton"
        app:layout_constraintWidth_max="360dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
