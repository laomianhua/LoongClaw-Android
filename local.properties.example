# 复制本文件为 local.properties，填入你的本机 SDK 路径和 API Key。
# local.properties 不会被 Git 提交。

sdk.dir=C\:\\Users\\你的用户名\\AppData\\Local\\Android\\Sdk
DEEPSEEK_API_KEY=sk-你的密钥

# 火山引擎 ASR（语音识别）— 在火山引擎控制台获取
VOLC_APPID=你的AppId
VOLC_TOKEN=你的Token
# 一句话识别 cluster（LOCAL 模式 / HTTP v1）
VOLC_CLUSTER=volcengine_input_common
# 流式语音识别 cluster（OPENCLAW 模式；控制台「流式语音识别」详情页复制 Cluster ID）
VOLC_STREAMING_CLUSTER=volcengine_streaming_common

# ── OpenClaw Shell（可选）──
# true：切换为 Gateway 哑终端模式；false：LOCAL v2.0 本地智能记事本
USE_OPENCLAW_SHELL=false
# true：使用 Mock 客户端联调 UI；false：连接真实 Gateway
USE_OPENCLAW_MOCK=true
OPENCLAW_GATEWAY_HOST=192.168.1.55
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_PASSWORD=clawbot-test-2024
OPENCLAW_GATEWAY_TOKEN=

# 高德地图 Android SDK — 在高德开放平台申请 Android 平台 Key（非 Web 服务 Key）
# 包名 com.littlehelper，调试 SHA1 可用：.\gradlew signingReport
AMAP_API_KEY=你的Android_SDK_Key
